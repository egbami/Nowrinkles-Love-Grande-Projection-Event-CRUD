generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Participant {
  id        String    @id @default(uuid())
  nom       String
  prenom    String
  whatsapp  String    @unique
  createdAt DateTime  @default(now())
  verifie   Boolean   @default(false)
  verifieAt DateTime?

  @@map("participants")
}
